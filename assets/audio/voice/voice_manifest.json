{
  "version": 2,
  "notes": "Two-language voice structure. Record each line as separate .ogg file with identical id in ru/en subfolders.",
  "channels": {
    "lore": {
      "enabledByDefault": true,
      "locales": {
        "ru": {
          "sourceText": "assets/audio/voice/lore/ru/lore_voice_lines_ru.txt",
          "outputDir": "assets/audio/voice/lore/ru"
        },
        "en": {
          "sourceText": "assets/audio/voice/lore/en/lore_voice_lines_en.txt",
          "outputDir": "assets/audio/voice/lore/en"
        }
      }
    },
    "quests": {
      "enabledByDefault": true,
      "locales": {
        "ru": {
          "sourceText": "assets/audio/voice/quests/ru/quest_voice_lines_ru.txt",
          "outputDir": "assets/audio/voice/quests/ru"
        },
        "en": {
          "sourceText": "assets/audio/voice/quests/en/quest_voice_lines_en.txt",
          "outputDir": "assets/audio/voice/quests/en"
        }
      }
    },
    "npcDialogue": {
      "enabledByDefault": true,
      "locales": {
        "ru": {
          "sourceText": "assets/audio/voice/npc_dialogues/ru/npc_dialogue_lines_ru.txt",
          "outputDir": "assets/audio/voice/npc_dialogues/ru"
        },
        "en": {
          "sourceText": "assets/audio/voice/npc_dialogues/en/npc_dialogue_lines_en.txt",
          "outputDir": "assets/audio/voice/npc_dialogues/en"
        }
      }
    }
  },
  "naming": {
    "example": "lore_line_001.mp3",
    "format": "line_id.mp3",
    "sampleRate": 44100,
    "formatAudio": "mp3"
  }
}